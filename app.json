{
  "expo": {
    "name": "Mundo play TV",
    "slug": "mundoplaytv-app",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "mundoplaytv",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "android": {
      "package": "com.mundoplaytv.app",
      "versionCode": 1,
      "permissions": [
        "INTERNET"
      ]
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ]
  }
}
